{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/uno-game/package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "pnpm install",
        "buildCommand": "cd ../../ && pnpm --filter @workspace/uno-game build",
        "outputDirectory": "artifacts/uno-game/public"
      }
    },
    {
      "src": "artifacts/api-server/package.json",
      "use": "@vercel/node",
       "config": {
        "installCommand": "pnpm install",
        "buildCommand": "cd ../../ && pnpm --filter @workspace/api-server build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
