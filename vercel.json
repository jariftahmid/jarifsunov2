{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/uno-game/package.json",
      "use": "@vercel/static-build",
      "config": { "outputDirectory": "public" }
    },
    {
      "src": "artifacts/api-server/package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}